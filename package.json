{
	"private": true,
	"workspaces": [
		"packages/core",
		"packages/prose",
		"packages/react",
		"packages/vue",
		"examples"
	],
	"scripts": {
		"build": "bun run build:core && bun run build:prose && bun run build:react && bun run build:vue",
		"build:core": "cd packages/core && tsc",
		"build:prose": "cd packages/prose && tsc",
		"build:react": "cd packages/react && tsc",
		"build:vue": "cd packages/vue && tsc",
		"build:examples": "cd examples && bun run build",
		"typecheck:examples": "cd examples && tsc --noEmit",
		"test": "bun test --recursive",
		"lint": "biome check packages examples/src benchmarks scripts",
		"format": "biome format --write packages examples/src benchmarks scripts",
		"check:diff": "git diff --check",
		"check:deps": "bun run scripts/check-dependencies.ts",
		"check:packages": "bun run scripts/check-packages.ts",
		"check:publish": "bun run scripts/check-publish-versions.ts",
		"verify": "bun run lint && bun run check:deps && bun run build && bun run check:packages && bun run test && bun run typecheck:examples && bun run build:examples && bun run check:diff",
		"verify:perf": "bun run scripts/check-benchmarks.ts",
		"verify:push": "bun run verify && bun run verify:perf",
		"hooks:install": "git config core.hooksPath .githooks",
		"prepare": "git config core.hooksPath .githooks || true",
		"bench": "bun run benchmarks/core.bench.ts",
		"bench:json": "bun run benchmarks/core.bench.ts --json",
		"bench:ssr": "bun run benchmarks/ssr.bench.tsx",
		"bench:browser": "bun run benchmarks/browser.bench.ts",
		"bench:all": "bun run bench && bun run bench:ssr && bun run bench:browser"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@tanstack/react-virtual": "^3.13.23",
		"@tanstack/virtual-core": "^3.13.23",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"playwright": "^1.58.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-virtuoso": "^4.18.3",
		"typescript": "^5.7.0",
		"vite": "^8.0.3"
	},
	"trustedDependencies": [
		"@biomejs/biome"
	]
}
