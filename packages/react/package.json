{
	"name": "@preflow/react",
	"version": "0.0.1",
	"description": "React components and hooks for preflow virtualization",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
