{
	"name": "@preflow/core",
	"version": "0.0.4",
	"description": "Predictive virtualization engine — heights from arithmetic, not DOM measurement",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
